LIST        p=18f4550
INCLUDE     <p18f4550.inc>

ARG_1   EQU     0x00
ARG_2   EQU     0x01
RESULT  EQU     0x02
COUNT   EQU     0x03
COUNT_2 EQU     0x04

ORG 0x00
GOTO Main

SAT_MUL
    MOVF ARG_2, W
    MOVWF COUNT

OUTER_LOOP
    MOVF ARG_1, W
    MOVWF COUNT_2

INNER_LOOP

    MOVLW D'1'
    ADDWF RESULT, F

    BTFSC STATUS, C
    GOTO OVERFLOW

    DECFSZ COUNT_2, F
    GOTO INNER_LOOP

    DECFSZ COUNT, F
    GOTO OUTER_LOOP

    RETURN

OVERFLOW
    MOVLW D'255'
    MOVWF RESULT
    RETURN

Main

    CLRF RESULT
    CLRF COUNT
    CLRF COUNT_2

    MOVLW D'5'
    MOVWF ARG_1

    MOVLW D'3'
    MOVWF ARG_2

    CALL SAT_MUL
    
    CLRF RESULT
    CLRF COUNT
    CLRF COUNT_2

    MOVLW D'5'
    MOVWF ARG_1

    MOVLW D'100'
    MOVWF ARG_2

    CALL SAT_MUL


END